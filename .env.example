# 复制本文件为项目根目录下的 .env 并填写（.env 已被 Git 忽略，勿提交）
#
# 路径：与 project.godot 同目录，即 Godot 里的 res://.env（本仓库 slayword/.env）。
# 用于 tools/generate_vocab_examples.py 等脚本；Godot 运行游戏时也会读取（与脚本相同变量名，见 VocabStudy）。
# 若 .env 放在其它磁盘路径，可设置系统环境变量 DOTENV_PATH=绝对路径（先于 res://.env 尝试）。

OPENAI_API_KEY=

# API 根地址，不要末尾斜杠；脚本会自动拼接 /chat/completions
# 官方默认：https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 若使用代理或兼容端已提供完整路径，可改用下面一项（设置后优先于 OPENAI_BASE_URL）
# OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions

# 兼容旧变量名（与 OPENAI_BASE_URL 二选一即可）
# OPENAI_API_BASE=https://api.openai.com/v1

OPENAI_MODEL=gpt-4o-mini

# 亦可在对局「暂停」界面填写 API Key 并点击生成（写入 user://vocab_books/）。
#
# 例句领域（逗号/中文逗号分隔，与游戏内暂停菜单勾选合并；CLI --domains 优先）
# 可与预设 id 混用：film_tv,anime,exam_style,daily,news,game_scifi；也可直接写中文
# VOCAB_EXAMPLE_DOMAINS=影视,考研真题

# 可选：指定其它位置的 env 文件
# DOTENV_PATH=D:/secrets/slayword.env
