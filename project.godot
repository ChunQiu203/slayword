; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Slay The Robot"
run/main_scene="res://scenes/Root.tscn"
config/features=PackedStringArray("4.6")
config/icon="uid://8kopj5luv8dc"

[autoload]

Signals="*res://autoload/Signals.gd"
Scenes="*res://autoload/Scenes.gd"
Scripts="*res://autoload/Scripts.gd"
FileLoader="*res://autoload/FileLoader.gd"
I18N="*res://autoload/I18N.gd"
Random="*res://autoload/Random.gd"
Global="*res://autoload/Global.gd"
VocabStudy="*res://autoload/VocabStudy.gd"
ActionHandler="*res://autoload/ActionHandler.gd"
ActionGenerator="*res://autoload/ActionGenerator.gd"
DebugLogger="*res://autoload/DebugLogger.gd"
UIDGenerator="*res://autoload/UIDGenerator.gd"

[debug]

gdscript/warnings/unused_signal=0
gdscript/warnings/integer_division=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="expand"
